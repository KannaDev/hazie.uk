<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/styles/blog.css" />
  </head>
  <body>
    {{ content }}
    <h2>Posts</h2>
    {{ for post of search.pages("url^=/blog/ visible=true", "date=desc") }}
      <span class="monospace">{{ post.date.toLocaleDateString("en-CA") }}</span>
      - <a href="{{ post.url }}">{{ post.title }}</a><br />
    {{ /for }}
    <hr />
    <footer>
      {{ comp.Footer() }}
    </footer>
  </body>
</html>
